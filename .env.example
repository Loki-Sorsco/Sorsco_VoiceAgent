# Copy this file to .env and fill in your keys.

# Groq — the bot's brain (FREE tier: ~1000 requests/day, no card needed).
# Get a key at https://console.groq.com -> API Keys
GROQ_API_KEY=...

# Sarvam AI — Indian-language STT + TTS for the VOICE bot (free credits on signup).
# Get a key at https://dashboard.sarvam.ai
# Not needed for run_text.py.
SARVAM_API_KEY=...

# Which client config to load from clients/ (filename without .json)
CLIENT_ID=hotel_sunrise
LLM_PROVIDER=groq

# --- Optional ---
# LLM_PROVIDER=google          # Gemini free tier is only ~20 requests/DAY
# GOOGLE_API_KEY=...           # from https://aistudio.google.com
# LLM_PROVIDER=anthropic       # if you have a paid Claude key
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=llama-3.3-70b-versatile   # override the model for any provider
